# Copie este arquivo para .env e preencha com sua chave real.
# NUNCA commite o arquivo .env no git.
GEMINI_API_KEY=sua_chave_aqui

# Modelo usado para ler as plantas. gemini-3.1-flash-lite e o mais barato
# disponivel atualmente e da conta bem de extracao estruturada simples.
# Troque para gemini-3.5-flash se precisar de mais precisao em plantas
# complexas. Se aparecer erro 404 "no longer available", confira o nome
# atual em https://ai.google.dev/gemini-api/docs/changelog
GEMINI_MODEL=gemini-3.1-flash-lite

# Deixe true para testar a interface sem gastar chamadas de API
MOCK_AI=false

# Deixe true para reaproveitar respostas ja obtidas para a mesma planta
USE_CACHE=true
